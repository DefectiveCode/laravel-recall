{
  "name": "defectivecode/skeleton",
  "type": "laravel",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "DefectiveCode\\Skeleton\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DefectiveCode\\Skeleton\\Tests\\": "tests"
    }
  },
  "authors": [
    {
      "name": "Corey McCormick",
      "email": "corey@defectivecode.com"
    }
  ],
  "require": {
    "php": ">=8.5"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0",
    "nunomaduro/collision": "^8.0",
    "phpunit/phpunit": "^12.0",
    "laravel/pint": "^1.8"
  },
  "scripts": {
    "post-autoload-dump": [
      "@php vendor/bin/testbench package:discover --ansi"
    ]
  }
}
